# backend/.env 파일에 올바른 URL 설정
PROMETHEUS_URL=http://172.16.17.200:9090
DATABASE_URL=postgresql://postgres:acest@172.16.17.200:5432/postgres

# CORS: 프론트엔드 출처 (운영 + 로컬 개발). 접속하는 브라우저 주소(Origin)를 모두 포함할 것
CORS_ORIGINS=http://172.16.17.200,http://localhost:5173,http://127.0.0.1:5173
# 백엔드에서 프로메테우스 요청 주기
PROMETHEUS_STEP=1m
PROMETHEUS_POLL_INTERVAL_SEC=60